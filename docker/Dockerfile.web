# =============================================================================
# P&ID Inteligente — Web UI (React + Vite)
# Multi-stage: Node 20 builds, nginx:alpine serves. Final image < 50 MB.
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Builder — install deps and build production bundle
# ---------------------------------------------------------------------------
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package manifests first for better layer caching
COPY packages/pid-web/package.json packages/pid-web/package-lock.json* ./
RUN npm ci --ignore-scripts

# Copy source and build
COPY packages/pid-web/ .
RUN npm run build

# ---------------------------------------------------------------------------
# Stage 2: Serve — nginx:alpine with the SPA bundle
# ---------------------------------------------------------------------------
FROM nginx:alpine

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Copy custom nginx config
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# Copy built assets from builder
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
