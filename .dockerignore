# Version control
.git
.gitignore

# Node.js
node_modules
npm-debug.log*

# Python
__pycache__
*.pyc
*.pyo
.venv
.pytest_cache
*.egg-info

# Environment files
.env
.env.*

# Documentation and specs (not needed in containers)
docs/
specs/
prompts/

# Testing artifacts
e2e/
coverage/
playwright-report/
test-results/
.coverage
htmlcov/

# CI/CD and editor config
.github/
.claude/

# Build artifacts
dist/
build/

# Neo4j local data
neo4j-data/

# Markdown files (except package READMEs, which are excluded by context path anyway)
*.md
!packages/*/README.md

# IDE
.vscode/
.idea/
*.swp
*.swo
